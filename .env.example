# Kopier denne fila til .env og fyll inn ekte verdier.
# .env er gitignorert og havner aldri i git.
#
# Project URL (Supabase → Project Settings → API)
SUPABASE_URL=https://DITT-PROSJEKT.supabase.co
#
# Publiserbar nøkkel (sb_publishable_…) — laget for frontend, trygg her.
# IKKE legg inn secret-nøkkelen (sb_secret_…) — den er backend-only.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_DIN-NOKKEL
#
# Service-role/secret-nøkkel (sb_secret_… / service_role JWT) — KUN server-side.
# Brukes av route handlers (bibliotek + relevante sjekkpunkt) til å lese
# datamodell/dokument_data, som har RLS begrenset til innloggede brukere;
# server-rutene har ingen brukersesjon. HEMMELIG: ALDRI eksponer til
# nettleseren og ALDRI bruk NEXT_PUBLIC-prefiks. Mangler den, faller
# funksjonene tilbake til innebygde defaults.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_DIN-NOKKEL
#
# Valgfritt — tabellnavn (standard: dokument_data)
SUPABASE_TABLE=dokument_data
#
# Base-URL til Sjekkliste-Plan-API-et som bibliotek-funksjonen henter
# datamodell-korpuset fra (server-side). Default er den publiserte Azure-
# tjenesten; sett til http://localhost:8082 når du kjører API-et lokalt.
SJEKKLISTE_API_BASE=https://ca-web-dibkplansjekk-poc.bluesea-86bb7fc5.norwayeast.azurecontainerapps.io
